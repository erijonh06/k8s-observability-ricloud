{
  "dashboard": {
    "title": "API Metrics",
    "panels": [
      {
        "type": "graph",
        "title": "HTTP Requests",
        "targets": [
          {
            "expr": "http_requests_total",
            "legendFormat": "{{handler}}",
            "refId": "A"
          }
        ]
      },
      {
        "type": "graph",
        "title": "Worker Jobs",
        "targets": [
          {
            "expr": "worker_jobs_total",
            "legendFormat": "jobs",
            "refId": "B"
          }
        ]
      }
    ]
  }
}
